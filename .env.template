# SIH Salus - variables de entorno
#
# Desarrollo:
#   cp .env.template .env
#   docker compose up -d
#
# Producción: reemplaza todos los valores de ejemplo y fija tags de imagen.
# También puedes generar un archivo seguro con:
#   ./scripts/security/secrets_generate.sh

# Selección persistente del stack (recomendada en servidores)
# Evita omitir accidentalmente un override en comandos posteriores.
# HTTPS:
# COMPOSE_FILE=docker-compose.yml:compose/ssl.yml
# COMPOSE_PROFILES=ssl
# Keycloak + HTTPS:
# COMPOSE_FILE=docker-compose.yml:compose/keycloak.yml:compose/ssl.yml
# COMPOSE_PROFILES=keycloak,ssl

# Core
OPENMRS_DB_USER=openmrs
MYSQL_OPENMRS_PASSWORD=openmrs
MYSQL_ROOT_PASSWORD=openmrs
OMRS_OCL_TOKEN=

# Imágenes. En producción usa tags inmutables (por ejemplo sha-...).
BACKEND_TAG=latest
FRONTEND_SOURCE_TAG=latest
FRONTEND_RUNTIME_TAG=latest
# FRONTEND_RUNTIME_IMAGE=sihsalus-frontend-runtime
STRIP_SOURCE_MAPS=true

# Réplica y backup MariaDB
# OMRS_DB_REPL_USER=openmrs_repl
# OMRS_DB_REPL_PASSWORD=
# OMRS_DB_BACKUP_USER=openmrs_backup
# OMRS_DB_BACKUP_PASSWORD=

# Gateway
# FRAME_ANCESTORS=
# FUA_CONFIG=
# FUA_LOCATIONS=

# FUA: docker compose --profile fua up -d
# FUA_GENERATOR_IMAGE=marcelius733/fua-generator
# FUA_GENERATOR_TAG=dev-0.1.7
# SIHSALUS_FUA_GEN_DB_USER=fuagenerator
# SIHSALUS_FUA_GEN_DB_PASSWORD=
# SIHSALUS_FUA_GEN_DB=fuagenerator
# SIHSALUS_FUA_GEN_TOKEN=
# SIHSALUS_FUA_GEN_SECRET_KEY=

# Indicadores: docker compose --profile indicadores up -d
# REPORTES_SQL_IMAGE=ghcr.io/sihsalus/reportes-sql
# REPORTES_SQL_TAG=latest
# SIHSALUS_REPORTES_SQL_DB=reportes_sql
# SIHSALUS_REPORTES_SQL_DB_USER=reportes_sql
# SIHSALUS_REPORTES_SQL_DB_PASSWORD=

# HAPI FHIR: docker compose --profile hapi up -d
# HAPI_IMAGE=johanamador/hapi-fhir-minsa-peru
# HAPI_TAG=latest
# HAPI_PORT=8085
# HAPI_DB_USER=hapi
# HAPI_DB_PASSWORD=
# HAPI_DB_NAME=hapi

# Keycloak (requiere cargar compose/keycloak.yml)
# docker compose -f docker-compose.yml -f compose/keycloak.yml --profile keycloak up -d
# KEYCLOAK_ADMIN=admin
# KEYCLOAK_ADMIN_PASSWORD=
# KC_DB_DATABASE=keycloak
# KC_DB_USERNAME=keycloak
# KC_DB_PASSWORD=
# KC_HOSTNAME=localhost
# KEYCLOAK_PORT=8180
# KEYCLOAK_PUBLIC_URL=http://localhost:8180
# OAUTH2_CLIENT_SECRET=
# OAUTH2_ENABLED no es configurable: core=false y el override Keycloak=true.

# Monitoring: docker compose --profile monitoring up -d
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=
# GRAFANA_ROOT_URL=http://localhost:3001

# Imaging: docker compose --profile imaging up -d
# ORTHANC_AUTHENTICATION_ENABLED=false

# Status (requiere cargar compose/status.yml)
# GATUS_PORT=8086

# HTTPS (requiere cargar compose/ssl.yml)
# SSL_MODE=dev
# CERT_WEB_DOMAINS=localhost,127.0.0.1
# CERT_WEB_DOMAIN_COMMON_NAME=
# CERT_CONTACT_EMAIL=
# SSL_STAGING=false
# CERT_PROFILE=
# GATEWAY_HTTPS_PORT=443
# CERT_RSA_KEY_SIZE=2048
# CERT_TEMP_CERT_DAYS=365
# CERT_NGINX_STARTUP_WAIT=10
# CERT_RENEWAL_INTERVAL=12h
# CERT_ORG=Centro de Salud
# CERT_OU=sihsalus
# CERT_COUNTRY=PE
# CERT_STATE=Loreto
# CERT_LOCALITY=Maynas

# Seed restore (requiere cargar compose/seed.yml)
# SIHSALUS_SEED_URL=
# SIHSALUS_SEED_SHA256=
# SIHSALUS_SEED_FORCE=false
